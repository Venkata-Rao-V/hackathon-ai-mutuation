// ────────────────────────────────────────────────────────────────
// AI Mutation Testing — Dev Container Configuration
// Python 3.11 + Node 20 + g++ are provided by the custom Dockerfile.
// Lifecycle hooks:
//   onCreateCommand   – builds the .vsix (once, after container is created)
//   postStartCommand  – starts the FastAPI core service in the background
//   postAttachCommand – installs the built .vsix into the running VS Code instance
// ────────────────────────────────────────────────────────────────
{
  "name": "AI Mutation Testing",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",

  // Companion extensions auto-installed from the marketplace.
  // The local AI Mutation Tester extension is installed via postAttachCommand.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode.cpptools",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "mutationTesting.coreServiceUrl": "http://localhost:8000",
        "mutationTesting.grafanaUrl": "http://localhost:3000",
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true
      }
    }
  },

  // ── Lifecycle hooks ──────────────────────────────────────────

  // Runs once when the container is first created:
  //   • Sync npm deps, compile TypeScript, pack .vsix
  "onCreateCommand": "bash /workspace/.devcontainer/build-extension.sh",

  // Runs every time the container starts:
  //   • Starts the FastAPI core mutation service on port 8000
  "postStartCommand": "bash /workspace/.devcontainer/start-core-service.sh",

  // Runs every time VS Code attaches to the container:
  //   • Installs the packed .vsix into the VS Code Server instance
  "postAttachCommand": "code --install-extension /workspace/vscode-extension/ai-mutation-testing.vsix --force",

  // ── Environment ────────────────────────────────────────────

  // Forward host API keys into the container (set them in your shell or .env).
  // Never hard-code secrets here.
  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },

  // ── Port forwarding ───────────────────────────────────────

  "forwardPorts": [8000, 3000, 9090],
  "portsAttributes": {
    "8000": {
      "label": "Core Mutation Service (FastAPI)",
      "onAutoForward": "silent"
    },
    "3000": {
      "label": "Grafana Dashboard",
      "onAutoForward": "notify"
    },
    "9090": {
      "label": "Prometheus Metrics",
      "onAutoForward": "silent"
    }
  },

  "remoteUser": "vscode"
}
